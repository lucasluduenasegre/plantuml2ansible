# ansible/routing.yml
# Generated by plantuml2ansible - do not edit manually.
---
{% for router_id, router_data in routers.items() %}
- name: Configure routing on {{ router_data.label }}
  hosts: {{ router_data.label }}
  become: true
  tasks:
    - name: Enable IP forwarding
      ansible.posix.sysctl:
        name: net.ipv4.ip_forward
        value: "1"
        state: present
        reload: true
{% if not loop.last %}

{% endif %}
{% endfor %}